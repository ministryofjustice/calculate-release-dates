
{% extends "../../partials/layout.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}

{% set pageTitle = applicationName + " - calculation summary" %}
{% set pageId = "calculation-summary" %}

{% block beforeContent %}
    {{ super() }}
    {{ govukBackLink({
        text: "Back",
        href: backLink,
        attributes: {"data-qa": "back-link"}
    }) }}
{% endblock %}

{% block content %}
    {% include "../partials/calculationSummary/secondCheckSummarySection.njk" %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">

                <h3 class="govuk-heading-m govuk-!-margin-top-4">What to do if the dates are wrong</h3>
                <p class="govuk-body">If something is wrong with the dates, check the sentence and offence information is correct
                then calculate release dates again.</p>
                <form method="post">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>

                    {{ govukButton({
                        text: "Confirm and continue",
                        value: 'save',
                        preventDoubleClick: true,
                        type: submit,
                        attributes: { 'data-qa': 'submit-to-nomis' }
                    }) }}

                     <a data-qa="cancel-link"
                            data-prevent-double-click="true" class="govuk-button govuk-!-margin-left-3 govuk-button--secondary no-js-hidden"
                            data-module="govuk-button"
                            href="{{ cancelUrl }}">
                            Cancel
                    </a>

            </form>
        </div>
    </div>
{% endblock %}
